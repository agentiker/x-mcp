# X API credentials
# Get these from https://developer.x.com/en/portal/dashboard
# Never commit a real .env file.

# OAuth 1.0a. Required for user-context reads and any write operation.
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# OAuth 2.0 Bearer Token. Used for app-context read operations.
X_BEARER_TOKEN=your_bearer_token_here

# Optional OAuth 2.0 user authorization for bookmarks.
# Set the same redirect URI in the X Developer Portal.
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
X_OAUTH2_REDIRECT_URI=http://127.0.0.1:3219/callback
# Least-privilege default for reading bookmarks.
# Add bookmark.write only if you intentionally enable bookmark_tweet/unbookmark_tweet.
X_OAUTH2_SCOPES=bookmark.read tweet.read users.read offline.access
# Optional. Defaults to ./.oauth2-tokens.json and is written with 0600 permissions.
X_OAUTH2_TOKEN_FILE=

# Write safety defaults.
# This server starts read-only and dry-run by default.
X_MCP_ENABLE_WRITES=false
X_MCP_DRY_RUN=true
X_MCP_REQUIRE_CONFIRMATION=true

# Per-action write gates. These only matter after X_MCP_ENABLE_WRITES=true.
X_MCP_ALLOW_POSTS=true
X_MCP_ALLOW_REPLIES=false
X_MCP_ALLOW_DELETES=false
X_MCP_ALLOW_ENGAGEMENTS=false
X_MCP_ALLOW_BOOKMARKS_WRITE=false
X_MCP_ALLOW_MEDIA_UPLOADS=false

# Optional disclosure appended to outgoing posts.
# Leave blank for no disclosure. Use \n for line breaks.
X_MCP_DISCLOSURE_TEXT=
